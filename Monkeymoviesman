!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>MonkeTube 3D | Jman POV Special</title>
    <script src="https://cloudflare.com"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Courier New', Courier, monospace; }
        body { background: #000; color: #0f0; overflow: hidden; }
        
        /* HUD / UI Overlay */
        #hud { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 10; border: 20px solid transparent; transition: border 0.1s; }
        #captions { position: absolute; bottom: 15%; width: 100%; text-align: center; font-size: 28px; font-weight: bold; text-shadow: 2px 2px #000; color: #fff; }
        
        /* Menu */
        #menu { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 20; text-align: center; background: rgba(0,0,0,0.9); padding: 40px; border: 4px solid #fbc02d; border-radius: 20px; }
        .btn { padding: 15px 30px; background: #fbc02d; color: #000; border: none; border-radius: 10px; font-size: 20px; font-weight: bold; cursor: pointer; }
    </style>
</head>
<body>

    <div id="hud">
        <div id="captions">SYSTEM: WAITING FOR MONKE...</div>
    </div>

    <div id="menu">
        <h1 style="color: #fbc02d; margin-bottom: 20px;">jmanTV 3D SPECIAL</h1>
        <p style="color: #aaa; margin-bottom: 30px;">"The City Ghost & The Banning of K9"</p>
        <button class="btn" onclick="startSpecial()">START VR POV (1 HOUR)</button>
    </div>

    <script>
        let scene, camera, renderer, k9, ghost, hands;
        let isSpecialRunning = false;

        // --- 1. SETUP GTAG 3D GRAPHICS ---
        function init3D() {
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x050505);
            camera = new THREE.PerspectiveCamera(90, window.innerWidth / window.innerHeight, 0.1, 1000);
            
            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            document.body.appendChild(renderer.domElement);

            // Lighting (Low light City Mall vibe)
            const ambient = new THREE.AmbientLight(0x404040, 2);
            scene.add(ambient);
            const pointLight = new THREE.PointLight(0xfbc02d, 1, 100);
            pointLight.position.set(0, 10, 0);
            scene.add(pointLight);

            // City Floor
            const floorGeo = new THREE.PlaneGeometry(100, 100);
            const floorMat = new THREE.MeshStandardMaterial({ color: 0x111111 });
            const floor = new THREE.Mesh(floorGeo, floorMat);
            floor.rotation.x = -Math.PI / 2;
            scene.add(floor);

            // K9 (Yellow Gorilla Model)
            const monkeGeo = new THREE.SphereGeometry(1, 32, 32);
            const k9Mat = new THREE.MeshStandardMaterial({ color: 0xfbc02d });
            k9 = new THREE.Mesh(monkeGeo, k9Mat);
            k9.position.set(0, 1, -5);
            scene.add(k9);

            // Daisy09 (Pink Ghost)
            const ghostMat = new THREE.MeshStandardMaterial({ color: 0xff00ff, transparent: true, opacity: 0 });
            ghost = new THREE.Mesh(monkeGeo, ghostMat);
            ghost.position.set(5, 5, -10);
            scene.add(ghost);

            // Jman's Hands (POV)
            const handGeo = new THREE.BoxGeometry(0.4, 0.4, 0.8);
            const handMat = new THREE.MeshStandardMaterial({ color: 0x0088ff });
            hands = new THREE.Group();
            const leftHand = new THREE.Mesh(handGeo, handMat);
            leftHand.position.set(-1.5, -1, -2);
            const rightHand = new THREE.Mesh(handGeo, handMat);
            rightHand.position.set(1.5, -1, -2);
            hands.add(leftHand, rightHand);
            scene.add(hands);

            camera.position.y = 2;
            animate();
        }

        function animate() {
            requestAnimationFrame(animate);
            if (isSpecialRunning) {
                // Bobbing camera like Gorilla movement
                camera.position.y = 2 + Math.sin(Date.now() * 0.005) * 0.1;
                hands.position.y = Math.sin(Date.now() * 0.01) * 0.2;
                
                // Ghost float logic
                ghost.position.y = 4 + Math.sin(Date.now() * 0.002) * 2;
            }
            renderer.render(scene, camera);
        }

        // --- 2. REALISTIC VOICE & SCRIPT ---
        async function startSpecial() {
            document.getElementById('menu').style.display = 'none';
            isSpecialRunning = true;
            init3D();

            const script = [
                { s: "jman", t: "YO K9! Look at my hands! I'm moving so fast in City right now!" },
                { s: "k9", t: "Jman, stop branching for a second. Look at the bridge." },
                { s: "jman", t: "What? Is it a fan? I'll go say hi!" },
                { s: "k9", t: "No... it's not a fan. It has no nametag. Jman, it's PINK." },
                { s: "jman", t: "Pink? Like... Daisy? No way. She's not real, K9!" },
                { s: "k9", t: "SHE'S LOOKING AT ME! JMAN, I CAN'T MOVE! MY VR IS FREEZING!" },
                { s: "jman", t: "K9? Your character is... why are you turning into stone?" },
                { s: "ghost", t: "...", action: "show_ghost" },
                { s: "jman", t: "K9?! HE GOT BANNED! THE GHOST ACTUALLY BANNED K9!!" }
            ];

            for (let i = 0; i < 500; i++) { // 1-hour loop
                const line = script[i % script.length];
                if (line.action === "show_ghost") ghost.material.opacity = 0.6;
                if (line.t.includes("BANNED")) {
                    k9.material.color.set(0x555555); // Turn to stone
                    document.getElementById('hud').style.border = "20px solid red";
                }
                await speak(line.t, line.s);
            }
        }

        function speak(text, char) {
            return new Promise(resolve => {
                const talk = new SpeechSynthesisUtterance(text);
                const cap = document.getElementById('captions');
                
                if (char === "jman") {
                    talk.pitch = 1.8; talk.rate = 1.4;
                    cap.style.color = "#0088ff"; cap.innerText = "JMAN: " + text;
                } else if (char === "k9") {
                    talk.pitch = 0.8; talk.rate = 1.0;
                    cap.style.color = "#fbc02d"; cap.innerText = "K9: " + text;
                } else {
                    talk.pitch = 0.1; talk.rate = 0.5; // Ghost voice
                    cap.style.color = "#ff00ff"; cap.innerText = "???";
                }

                talk.onend = () => {
                    document.getElementById('hud').style.border = "20px solid transparent";
                    resolve();
                };
                window.speechSynthesis.speak(talk);
            });
        }
    </script>
</body>
</html>
